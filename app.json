{
  "expo": {
    "name": "TravelPlanner",
    "slug": "TravelPlanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "travelplanner",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "googleApiKey": "AIzaSyDePpq5y0hJpJFo6vkcHnr3ZJK5AkeVb9k",
      "router": {},
      "eas": {
        "projectId": "74e7368c-8886-46c3-9b91-dda8faf2885c"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDePpq5y0hJpJFo6vkcHnr3ZJK5AkeVb9k"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/74e7368c-8886-46c3-9b91-dda8faf2885c"
    }
  }
